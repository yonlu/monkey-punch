{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@mp/shared": ["../shared/src/index.ts"],
      "@/*": ["src/*"]
    },
    "types": ["vite/client"]
  },
  "references": [{ "path": "../shared" }],
  "include": ["src/**/*"]
}
