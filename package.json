{
  "name": "monkey-punch",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "pnpm --parallel -r --filter @mp/server --filter @mp/client run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "tsc -b",
    "clean": "pnpm -r exec rm -rf dist && rm -rf node_modules/.cache"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
